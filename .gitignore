# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
electron/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# electron-builder output (installers, unpacked app, update metadata)
/dist

# misc
.DS_Store
*.pem
recovery-codes.txt

# code-signing material — certificates/keys must never be committed; they
# belong in GitHub Secrets (see README "macOS: Code-Signing & Notarisierung")
*.p12
*.cer
*.mobileprovision
*.provisionprofile
*.keystore
*.jks
electron-builder-cache/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep the example template, ignore anything with real secrets
.env*
!.env.example

# vercel
.vercel

# local Claude Code session state — not project source
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts
