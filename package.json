{
  "name": "routinequest",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "electron:dev": "cross-env APP_URL=http://localhost:3000 electron .",
    "electron": "electron .",
    "icon": "node build/generate-icon.js",
    "dist:win": "electron-builder --win --publish never"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "nanoid": "^6.0.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "playwright": "^1.61.1",
    "png-to-ico": "^3.0.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true,
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "prisma@6.19.3": true,
    "electron-winstaller@5.4.0": true
  },
  "build": {
    "appId": "app.routinequest.desktop",
    "productName": "RoutineQuest",
    "asar": true,
    "artifactName": "RoutineQuest-Setup.exe",
    "directories": {
      "app": "electron",
      "output": "dist",
      "buildResources": "build"
    },
    "npmRebuild": false,
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "teshikado",
      "repo": "RoutineQuest",
      "releaseType": "release"
    }
  }
}
