generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Category {
  FITNESS
  LEARNING
  HEALTH
  PRODUCTIVITY
  HOUSEHOLD
  RELAXATION
  PERSONAL_GOALS
}

enum GroupRole {
  OWNER
  ADMIN
  MEMBER
}

enum ChallengeType {
  TASKS_COUNT
  STREAK_DAYS
  XP_TOTAL
  PERFECT_WEEK
}

enum NotificationType {
  ROUTINE_REMINDER
  STREAK_AT_RISK
  GROUP_INVITE
  GROUP_CHALLENGE
  LEVEL_UP
  RANK_UP
  WEEKLY_REPORT
  GROUP_ROUTINE_ADDED
  GROUP_ROUTINE_CHAMPION
}

enum ParticipationStatus {
  PENDING
  JOINED
  DECLINED
  LEFT
}

enum GroupRoutineStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum GroupRoutineVisibility {
  ALL_MEMBERS
  PARTICIPANTS_ONLY
}

enum GroupRoutineGoalType {
  NONE
  WEEKLY
}

enum GroupRoutineAwardType {
  CHAMPION
  STREAK_MEISTER
  COMEBACK_STAR
  TEAMPLAYER
  PERFECT_WOCHE
}

// ---------- Core user ----------

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  username       String?  @unique
  avatarEmoji    String   @default("🙂")
  avatarColor    String   @default("#4FA8D8")
  onboarded      Boolean  @default(false)
  totalXp        Int      @default(0)
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastActiveDate DateTime? @db.Date
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  routines           Routine[]
  completions        Completion[]
  xpTransactions     XpTransaction[]
  ownedGroups        Group[]              @relation("GroupOwner")
  groupMemberships   GroupMember[]
  sentInvites        GroupInvite[]        @relation("InviteCreator")
  userBadges         UserBadge[]
  notifications      Notification[]
  notificationPrefs  NotificationSetting[]
  passwordResetTokens PasswordResetToken[]
  createdGroupRoutines      GroupRoutine[]            @relation("GroupRoutineCreator")
  groupRoutineParticipations GroupRoutineParticipant[]
  groupRoutineCompletions   GroupRoutineCompletion[]
  groupRoutineAwards        GroupRoutineAward[]

  @@index([email])
  @@index([username])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- Routines ----------

model Routine {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  category    Category
  icon        String     @default("Sparkles")
  color       String     @default("#4FA8D8")
  difficulty  Difficulty @default(MEDIUM)
  scheduledDays Int[]    // 1 = Monday ... 7 = Sunday
  timeOfDay   String?    // "HH:mm"
  reminderEnabled Boolean @default(false)
  archived    Boolean    @default(false)
  archivedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  completions Completion[]

  @@index([userId])
  @@index([userId, archived])
}

model Completion {
  id          String   @id @default(cuid())
  routineId   String
  userId      String
  date        DateTime @db.Date
  xpAwarded   Int
  createdAt   DateTime @default(now())

  routine Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([routineId, date])
  @@index([userId, date])
}

model XpTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String   // TASK_COMPLETE | DAILY_COMPLETE | STREAK_MILESTONE | PERFECT_WEEK
  refDate   DateTime @db.Date
  refId     String   @default("") // completionId for TASK_COMPLETE, "daily" / weekKey otherwise
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reason, refDate, refId])
  @@index([userId, createdAt])
}

// ---------- Groups ----------

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String   @default("Users")
  color       String   @default("#4FA8D8")
  ownerId     String
  maxMembers  Int?
  isPrivate   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner      User          @relation("GroupOwner", fields: [ownerId], references: [id])
  members    GroupMember[]
  invites    GroupInvite[]
  challenges Challenge[]
  groupRoutines GroupRoutine[]

  @@index([ownerId])
}

model GroupMember {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

model GroupInvite {
  id        String    @id @default(cuid())
  groupId   String
  code      String    @unique
  createdById String
  expiresAt DateTime?
  maxUses   Int?
  useCount  Int       @default(0)
  revoked   Boolean   @default(false)
  createdAt DateTime  @default(now())

  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User  @relation("InviteCreator", fields: [createdById], references: [id])

  @@index([groupId])
}

model Challenge {
  id          String        @id @default(cuid())
  groupId     String
  title       String
  description String?
  type        ChallengeType
  target      Int
  startDate   DateTime      @db.Date
  endDate     DateTime      @db.Date
  completed   Boolean       @default(false)
  completedAt DateTime?
  createdAt   DateTime      @default(now())

  group      Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userBadges UserBadge[]

  @@index([groupId])
}

model Badge {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String
  icon        String
  color       String   @default("#FFD166")

  userBadges UserBadge[]
}

model UserBadge {
  id            String    @id @default(cuid())
  userId        String
  badgeId       String
  challengeId   String?
  groupRoutineId String?
  earnedAt      DateTime  @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge        Badge         @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  challenge    Challenge?    @relation(fields: [challengeId], references: [id], onDelete: SetNull)
  groupRoutine GroupRoutine? @relation(fields: [groupRoutineId], references: [id], onDelete: SetNull)

  @@unique([userId, badgeId, challengeId, groupRoutineId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model NotificationSetting {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  enabled Boolean          @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

// ---------- Group routines ----------

model GroupRoutine {
  id          String                 @id @default(cuid())
  groupId     String
  createdById String
  title       String
  description String?
  category    Category
  icon        String                 @default("Sparkles")
  color       String                 @default("#4FA8D8")
  difficulty  Difficulty             @default(MEDIUM)
  xpReward    Int
  startDate   DateTime               @db.Date
  endDate     DateTime?              @db.Date
  scheduledDays Int[] // 1 = Monday ... 7 = Sunday
  timeOfDay   String?                // "HH:mm"
  visibility  GroupRoutineVisibility @default(ALL_MEMBERS)
  mandatory   Boolean                @default(false)
  goalType    GroupRoutineGoalType   @default(NONE)
  goalTarget  Int?
  status      GroupRoutineStatus     @default(ACTIVE)
  pausedAt    DateTime?
  endedAt     DateTime?
  deletedAt   DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  group       Group                     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy   User                      @relation("GroupRoutineCreator", fields: [createdById], references: [id])
  participants GroupRoutineParticipant[]
  completions GroupRoutineCompletion[]
  awards      GroupRoutineAward[]
  userBadges  UserBadge[]

  @@index([groupId])
  @@index([groupId, status])
}

model GroupRoutineParticipant {
  id             String              @id @default(cuid())
  groupRoutineId String
  userId         String
  status         ParticipationStatus @default(PENDING)
  respondedAt    DateTime?
  joinedAt       DateTime?
  leftAt         DateTime?
  currentStreak  Int                 @default(0)
  longestStreak  Int                 @default(0)
  createdAt      DateTime            @default(now())

  groupRoutine GroupRoutine @relation(fields: [groupRoutineId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupRoutineId, userId])
  @@index([userId])
}

model GroupRoutineCompletion {
  id             String   @id @default(cuid())
  groupRoutineId String
  userId         String
  date           DateTime @db.Date
  xpAwarded      Int
  createdAt      DateTime @default(now())

  groupRoutine GroupRoutine @relation(fields: [groupRoutineId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupRoutineId, userId, date])
  @@index([userId, date])
  @@index([groupRoutineId, date])
}

model GroupRoutineAward {
  id             String                @id @default(cuid())
  groupRoutineId String
  weekKey        String
  userId         String
  type           GroupRoutineAwardType
  meta           Json?
  createdAt      DateTime              @default(now())

  groupRoutine GroupRoutine @relation(fields: [groupRoutineId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupRoutineId, weekKey, type, userId])
  @@index([groupRoutineId, weekKey])
}
