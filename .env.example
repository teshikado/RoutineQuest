# Copy this file to `.env` for local development.
#
# Local dev: point DATABASE_URL at a local Postgres instance (see README).
# Production (Vercel): set these as Environment Variables in the Vercel
# project settings instead of committing a real `.env` — DATABASE_URL should
# point at your hosted Postgres (e.g. Neon), and NEXTAUTH_URL should be your
# production domain (e.g. https://routinequest.vercel.app).

DATABASE_URL="postgresql://postgres:password@localhost:5432/routinequest?schema=public"

# Generate a real secret with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-secret"

NEXTAUTH_URL="http://localhost:3000"

# Optional — only needed if outgoing email (invites, password reset) should
# actually send. Left unset, emails are logged to the server console instead.
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="RoutineQuest <no-reply@example.com>"
